{
    "name": "@waldoapp/wdio-service",
    "version": "1.1.1",
    "description": "Webdriver.io service for Waldo",
    "homepage": "https://www.waldo.com/scripting",
    "bugs": {
        "url": "https://github.com/waldoapp/wdio-service/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/waldoapp/wdio-service.git"
    },
    "keywords": [
        "webdriver",
        "wdio",
        "wdio-service",
        "waldo"
    ],
    "engines": {
        "node": ">=18"
    },
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "build": "rm -rf dist && tsc",
        "build:pack": "rm -rf dist && tsc -p tsconfig.pack.json",
        "test": "vitest",
        "ci": "pnpm build && pnpm test --run && pnpm prettier:check && pnpm eslint:check",
        "prepack": "pnpm build:pack",
        "eslint:fix": "eslint --cache --cache-location=node_modules/.cache/eslint/ --fix .",
        "eslint:check": "eslint --cache --cache-location=node_modules/.cache/eslint/ .",
        "prettier:fix": "prettier --cache --write .",
        "prettier:check": "prettier --cache --check ."
    },
    "bin": {
        "waldo-auth": "dist/bin/waldo-auth.js"
    },
    "author": "developers@waldo.com",
    "license": "MIT",
    "dependencies": {
        "@wdio/logger": "^8.0.0 || ^9.0.0",
        "axios": "^1.0.0",
        "open": "^10.0.0",
        "sax": "^1.0.0",
        "webdriver": "^8.0.0 || ^9.0.0",
        "yaml": "^2.0.0"
    },
    "peerDependencies": {
        "webdriverio": "^8.0.0 || ^9.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.21.0",
        "@types/node": "^18.0.0",
        "@types/sax": "^1.2.7",
        "@wdio/globals": "^8.0.0 || ^9.0.0",
        "@wdio/protocols": "^8.0.0 || ^9.0.0",
        "@wdio/types": "^8.0.0 || ^9.0.0",
        "eslint": "^9.21.0",
        "eslint-config-prettier": "^9.1.0",
        "memfs": "^4.14.0",
        "prettier": "^3.5.3",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.14.0",
        "vitest": "^3.0.7"
    },
    "files": [
        "dist"
    ],
    "resolutions": {
        "fast-xml-parser": "^5.3.5",
        "basic-ftp": "^5.2.0"
    },
    "packageManager": "pnpm@10.23.0+sha512.21c4e5698002ade97e4efe8b8b4a89a8de3c85a37919f957e7a0f30f38fbc5bbdd05980ffe29179b2fb6e6e691242e098d945d1601772cad0fef5fb6411e2a4b"
}
